{
	"name": "@savvy-web/lint-staged",
	"version": "0.8.0",
	"private": false,
	"description": "Composable, configurable lint-staged handlers for pre-commit hooks. Provides reusable handlers for Biome, Markdown, YAML, TypeScript, and more.",
	"keywords": [
		"lint-staged",
		"pre-commit",
		"hooks",
		"biome",
		"markdown",
		"yaml",
		"typescript",
		"formatting",
		"linting"
	],
	"homepage": "https://github.com/savvy-web/lint-staged#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/lint-staged/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/lint-staged.git",
		"directory": "package"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./biome/silk.jsonc": "./src/public/biome/silk.jsonc"
	},
	"bin": {
		"savvy-lint": "./src/bin/cli.ts"
	},
	"scripts": {
		"build:dev": "rslib build --env-mode dev",
		"build:prod": "rslib build --env-mode npm",
		"generate:templates": "node lib/scripts/generate-markdownlint-template.ts",
		"prepare": "rslib build --config-loader native --env-mode dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/cli": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@savvy-web/silk-effects": "^0.2.2",
		"@typescript-eslint/parser": "^8.58.2",
		"effect": "catalog:silk",
		"eslint": "^10.2.0",
		"eslint-plugin-tsdoc": "^0.5.2",
		"jsonc-effect": "^0.2.1",
		"prettier": "^3.8.2",
		"sort-package-json": "^3.6.1",
		"workspaces-effect": "^0.3.0",
		"yaml": "^2.8.3",
		"yaml-lint": "^1.7.0"
	},
	"devDependencies": {
		"@savvy-web/rslib-builder": "^0.20.1",
		"@types/node": "catalog:silk",
		"@types/ws": "^8.18.1",
		"@typescript/native-preview": "catalog:silk",
		"turbo": "^2.9.6",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/node": "catalog:silkPeers",
		"@typescript/native-preview": "catalog:silkPeers",
		"husky": "^9.1.0",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.22.0",
		"markdownlint-cli2-formatter-codequality": "^0.0.7",
		"turbo": "^2.9.0",
		"typescript": "catalog:silkPeers"
	},
	"peerDependenciesMeta": {
		"@biomejs/biome": {
			"optional": true
		},
		"@types/node": {
			"optional": false
		},
		"@typescript/native-preview": {
			"optional": false
		},
		"husky": {
			"optional": false
		},
		"lint-staged": {
			"optional": false
		},
		"markdownlint-cli2": {
			"optional": false
		},
		"markdownlint-cli2-formatter-codequality": {
			"optional": false
		},
		"turbo": {
			"optional": false
		},
		"typescript": {
			"optional": false
		}
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
